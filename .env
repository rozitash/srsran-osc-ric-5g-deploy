## =============================================================================
## .env — Full Deployment Configuration
## Scenario 8: 1 CU, 1 DU, 1 Cell, USRP B210 + OSC Near-RT RIC
## =============================================================================

# ----------------------------- USRP B210 ------------------------------------
# Run 'uhd_find_devices' to get your serial. Leave empty for auto-detect.
USRP_SERIAL=34C78F0
USRP_TX_GAIN=70
USRP_RX_GAIN=70

# ----------------------------- Monitor ---------------------------------------
XAPP_PY_RUNNER_IP=10.0.2.20
XAPP_MONITOR_IP=10.0.2.21
CSV_SERVER_IP=172.25.1.7


# ----------------------------- Grafana ---------------------------------------
GF_VERSION=12.0.2
GF_PORT=3000
GF_LOGO_URL=https://raw.githubusercontent.com/srsran/srsRAN_Project_docs/main/docs/source/.imgs/logo.png
GF_AUTH_ANONYMOUS_ENABLED=true
GF_LOG_LEVEL=warning
GF_DASHBOARDS_MIN_REFRESH_INTERVAL=1s
GF_PLUGINS_PLUGIN_ADMIN_ENABLED=false

# ----------------------------- OSC Near-RT RIC --------------------------------
SC_RIC_VERSION=m-release
SYSTEM_NAME=oran_sc_ric
RIC_ID=7b0000-000000/18
RMR_LOG_VLEVEL=0

# RIC Network
RIC_SUBNET=10.0.2.0/24

# E2 Termination Point
E2TERM_VER=9.0.1
E2TERM_NAME=e2term
E2TERM_IP=10.0.2.10
E2TERM_SCTP_PORT=36421

# E2 Manager
E2MGR_VER=6.0.8
E2MGR_NAME=e2mgr
E2MGR_IP=10.0.2.11

# Database (Redis / SDL)
DBAAS_VER=0.6.5
DBAAS_NAME=dbaas
DBAAS_IP=10.0.2.12
DBAAS_PORT=6379
DBAAS_PORT_6379_TCP_ADDR=10.0.2.12
DBAAS_PORT_6379_TCP_PORT=6379
DBAAS_SERVICE_HOST=10.0.2.12
DBAAS_SERVICE_PORT=6379

# Subscription Manager
SUBMGR_VER=0.14.0
SUBMGR_NAME=submgr
SUBMGR_IP=10.0.2.13

# xApp Manager
APPMGR_VER=0.5.10
APPMGR_NAME=appmgr
APPMGR_IP=10.0.2.14

# Routing Manager Simulator
RTMGR_SIM_NAME=rtmgr
RTMGR_SIM_IP=10.0.2.15
RTMGR_SIM_PORT=12020

# Path to RIC configs (relative to clean_deploy/ where docker compose is run)
RIC_CONFIGS_PATH=./ric/configs
